<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="88dp"
            android:clipToPadding="false">

            <!-- ===== HEADER SECTION ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A2B45"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="32dp">

                <!-- Top Bar: Logo + Bell -->
                <LinearLayout
                    android:id="@+id/layoutTopBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Logo / App Name -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_bolt"
                            app:tint="#EAD820"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="SI UJANG GATRIK"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"/>
                    </LinearLayout>

                    <!-- Notification Bell -->
                    <ImageView
                        android:id="@+id/ivNotification"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_notifications"
                        app:tint="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Subtitle Label -->
                <TextView
                    android:id="@+id/tvKementerian"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/layoutTopBar"
                    android:layout_marginTop="24dp"
                    android:text="KEMENTERIAN ESDM"
                    android:textColor="#EAD820"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <!-- Main Title -->
                <TextView
                    android:id="@+id/tvMainTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvKementerian"
                    android:layout_marginTop="6dp"
                    android:text="Sistem Informasi Usaha Jasa Penunjang Tenaga Listrik"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp"/>

                <!-- Description -->
                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvMainTitle"
                    android:layout_marginTop="8dp"
                    android:text="Akses layanan ketenagalistrikan resmi dari Direktorat Jenderal Ketenagalistrikan."
                    android:textColor="#AABBCC"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp"/>

                <!-- Search Bar -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSearch"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_below="@id/tvDescription"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="6dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_search"
                            app:tint="#999999"/>

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:hint="Cek Status Permohonan..."
                            android:textColor="#1A2B45"
                            android:textSize="14sp"
                            android:background="@null"
                            android:inputType="text"
                            android:imeOptions="actionSearch"
                            android:maxLines="1"/>

                        <Button
                            android:id="@+id/btnCari"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Cari"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:backgroundTint="#1A2B45"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            app:cornerRadius="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </RelativeLayout>

            <!-- ===== SERVICE CARDS SECTION ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp"
                android:baselineAligned="false">

                <!-- Card: Sertifikat Laik Operasi -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSLO"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Icon Background -->
                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_circle_yellow">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_verified"
                                app:tint="#FFFFFF"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Sertifikat Laik Operasi (SLO)"
                            android:textColor="#1A2B45"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Pemeriksaan dan pengujian teknis instalasi."
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Pembangunan & Pemasangan -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPembangunan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Icon Background -->
                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_circle_light_gray">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bolt"
                                app:tint="#1A2B45"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Pembangunan &amp; Pemasangan"
                            android:textColor="#1A2B45"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Permohonan NIDI dan instalatir kontraktor."
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ===== INFORMASI TERBARU SECTION ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp">

                <!-- Section Header -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Informasi Terbaru"
                        android:textColor="#1A2B45"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvLihatSemua"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Lihat Semua ›"
                        android:textColor="#1A2B45"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </RelativeLayout>

                <!-- News Item 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNews1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivNews1"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_news_placeholder"
                            android:background="#CCCCCC"
                            android:adjustViewBounds="true"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PENGUMUMAN"
                                android:textColor="#888888"
                                android:textSize="10sp"
                                android:letterSpacing="0.08"
                                android:textAllCaps="true"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Rekap Hasil Penilaian Kinerja Lembaga Sertifikasi 2024-2025"
                                android:textColor="#1A2B45"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:lineSpacingExtra="2dp"
                                android:maxLines="3"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:src=" @drawable/ic_calendar"
                                    app:tint="#AAAAAA"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:text="12 Mar 2024"
                                    android:textColor="#AAAAAA"
                                    android:textSize="11sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- News Item 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNews2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivNews2"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_news_placeholder"
                            android:background="#CCCCCC"
                            android:adjustViewBounds="true"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BERITA"
                                android:textColor="#888888"
                                android:textSize="10sp"
                                android:letterSpacing="0.08"
                                android:textAllCaps="true"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Penyesuaian Username Login Akun Badan Usaha Menggunakan Email SBU"
                                android:textColor="#1A2B45"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:lineSpacingExtra="2dp"
                                android:maxLines="3"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:src="@drawable/ic_calendar"
                                    app:tint="#AAAAAA"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:text="05 Feb 2024"
                                    android:textColor="#AAAAAA"
                                    android:textSize="11sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ===== BUTUH BANTUAN SECTION ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A2B45">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvBantuanTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Butuh Bantuan?"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvBantuanDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvBantuanTitle"
                        android:layout_marginTop="6dp"
                        android:text="Hubungi kami jika Anda memiliki kendala pada permohonan atau login."
                        android:textColor="#AABBCC"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"/>

                    <Button
                        android:id="@+id/btnHubungi"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_below="@id/tvBantuanDesc"
                        android:layout_marginTop="16dp"
                        android:text="🎧  Hubungi 136"
                        android:textColor="#1A2B45"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:backgroundTint="#EAD820"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        app:cornerRadius="22dp"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== AKSES CEPAT SECTION ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Akses Cepat"
                    android:textColor="#1A2B45"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <!-- Quick Access Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- FAQ -->
                    <LinearLayout
                        android:id="@+id/layoutFAQ"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_circle_light_gray">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_help_outline"
                                app:tint="#555555"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="FAQ"
                            android:textColor="#444444"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>

                    <!-- Tata Cara -->
                    <LinearLayout
                        android:id="@+id/layoutTataCara"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_circle_light_gray">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_article"
                                app:tint="#555555"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Tata Cara"
                            android:textColor="#444444"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>

                    <!-- Hukum -->
                    <LinearLayout
                        android:id="@+id/layoutHukum"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_circle_light_gray">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_gavel"
                                app:tint="#555555"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Hukum"
                            android:textColor="#444444"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>

                    <!-- Peta Jasa -->
                    <LinearLayout
                        android:id="@+id/layoutPetaJasa"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_circle_light_gray">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_map"
                                app:tint="#555555"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Peta Jasa"
                            android:textColor="#444444"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM NAVIGATION BAR ===== -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/bottom_nav"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>