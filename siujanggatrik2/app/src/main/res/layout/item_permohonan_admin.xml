<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Baris atas: ID + badge tipe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvIdPermohonan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NIDI-202600001"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#212121"/>

            <TextView
                android:id="@+id/tvTipePermohonan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NIDI"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_circle_primary"/>

        </LinearLayout>

        <!-- Nama pemohon -->
        <TextView
            android:id="@+id/tvNamaPermohonan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ahmad Subarjo"
            android:textSize="15sp"
            android:textColor="#424242"/>

        <!-- Jenis instalasi -->
        <TextView
            android:id="@+id/tvJenisInstalasi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Rumah Tinggal"
            android:textSize="13sp"
            android:textColor="#757575"/>

        <!-- Tanggal + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvTanggalPermohonan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12 Juli 2026"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:textColor="@color/black"
                android:id="@+id/tvStatusPermohonan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menunggu"
                android:textSize="12sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Tombol Detail -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailAdmin"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Lihat &amp; Tinjau"
            android:backgroundTint="@color/blue"
            android:textColor="@color/white"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>